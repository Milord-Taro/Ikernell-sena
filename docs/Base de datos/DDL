CREATE TABLE Rol (
    idRol           SERIAL          PRIMARY KEY,
    codRol          VARCHAR(10)     NOT NULL UNIQUE,
    nombreRol       VARCHAR(50)     NOT NULL,
    descripcionRol     TEXT            NOT NULL
);

CREATE TABLE Profesion (
    idProfesion     SERIAL          PRIMARY KEY,
    codProfesion    VARCHAR(10)     NOT NULL UNIQUE,
    nombreProfesion VARCHAR(100)    NOT NULL
);

CREATE TABLE Especialidad (
    idEspecialidad      SERIAL          PRIMARY KEY,
    codEspecialidad     VARCHAR(10)     NOT NULL UNIQUE,
    nombreEspecialidad  VARCHAR(100)    NOT NULL
);

CREATE TABLE Usuario (
    idUsuario               SERIAL          PRIMARY KEY,
    codUsuario              VARCHAR(10)     NOT NULL UNIQUE,
    nombre                  VARCHAR(100)    NOT NULL,
    apellido                VARCHAR(100)    NOT NULL,
    fechaNacimiento         DATE            NOT NULL,
	tipoIdentificacion		VARCHAR(20)     NOT NULL,
    numeroIdentificacion    VARCHAR(20)     NOT NULL UNIQUE,
    correoElectronico       VARCHAR(150)    NOT NULL UNIQUE,
    direccion               TEXT            NOT NULL,
    contrasena              VARCHAR(255)    NOT NULL,
    fotoPerfil              VARCHAR(255),
    estado                  BOOLEAN         NOT NULL DEFAULT TRUE,
    idRol                   INT             NOT NULL REFERENCES Rol(idRol),
    idProfesion             INT             NOT NULL REFERENCES Profesion(idProfesion),
    idEspecialidad          INT             REFERENCES Especialidad(idEspecialidad)
);

CREATE TABLE Proyecto (
    idProyecto      		SERIAL          PRIMARY KEY,
    codProyecto     		VARCHAR(10)     NOT NULL UNIQUE,
    nombreProyecto          VARCHAR(150)    NOT NULL,
    descripcionProyecto     TEXT            NOT NULL,
    fechaInicioProyecto     DATE            NOT NULL,
    fechaFinProyecto        DATE            NOT NULL,
    estadoProyecto          BOOLEAN         NOT NULL DEFAULT TRUE,
    idLider         		INT             NOT NULL REFERENCES Usuario(idUsuario)
);

CREATE TABLE AsignacionProyecto (
    idAsignacion        SERIAL          PRIMARY KEY,
    fechaAsignacion     DATE            NOT NULL,
    estadoAsignacion    BOOLEAN         NOT NULL DEFAULT TRUE,
    idUsuario           INT             NOT NULL REFERENCES Usuario(idUsuario),
    idProyecto          INT             NOT NULL REFERENCES Proyecto(idProyecto),
    CONSTRAINT uq_asignacion UNIQUE (idUsuario, idProyecto)
);

CREATE TABLE Etapa (
    idEtapa         	SERIAL          PRIMARY KEY,
    codEtapa        	VARCHAR(10)     NOT NULL UNIQUE,
    nombreEtapa         VARCHAR(150)    NOT NULL,
    descripcionEtapa    TEXT            NOT NULL,
    fechaEtapa          DATE            NOT NULL,
    idProyecto      	INT             NOT NULL REFERENCES Proyecto(idProyecto)
                                    	ON DELETE CASCADE
);

CREATE TABLE Actividad (
    idActividad         		SERIAL          PRIMARY KEY,
    codActividad        		VARCHAR(10)     NOT NULL UNIQUE,
    nombreActividad             VARCHAR(150)    NOT NULL, 
    descripcionActividad        TEXT            NOT NULL,
    fechaInicioActividad        DATE            NOT NULL,
    fechaFinActividad           DATE            NOT NULL,
    estadoActividad             VARCHAR(20)     NOT NULL DEFAULT 'Pendiente'
                                        		CHECK (estadoActividad IN ('Pendiente', 'Ejecutada')),
    fechaEjecucionActividad     DATE,
    idEtapa             		INT             NOT NULL REFERENCES Etapa(idEtapa)
                                        		ON DELETE CASCADE,
    idDesarrollador     		INT             NOT NULL REFERENCES Usuario(idUsuario)
);

CREATE TABLE TipoError (
    idTipoError     SERIAL          PRIMARY KEY,
    codTipoError    VARCHAR(10)     NOT NULL UNIQUE,
    nombreTipo      VARCHAR(100)    NOT NULL
);

CREATE TABLE RegistroError ( 
    idError             SERIAL          PRIMARY KEY,
    codError            VARCHAR(10)     NOT NULL UNIQUE,
    descripcionError    TEXT            NOT NULL,
    fechaRegistroError  DATE            NOT NULL DEFAULT CURRENT_DATE,
	estadoError 		VARCHAR(20) 	NOT NULL
										CHECK (estadoError IN ('Abierto','En Revision','Corregido',
										'No Reproducible','Descartado')),
	comentarioError 	TEXT,
	idTipoError         INT             NOT NULL REFERENCES TipoError(idTipoError),
    idEtapa             INT             NOT NULL REFERENCES Etapa(idEtapa)
                                        ON DELETE CASCADE,
    idDesarrollador     INT             NOT NULL REFERENCES Usuario(idUsuario)
);

CREATE TABLE TipoInterrupcion (
    idTipoInterrupcion      SERIAL          PRIMARY KEY,
    codTipoInterrupcion     VARCHAR(10)     NOT NULL UNIQUE,
    nombreTipoInterrupcion  VARCHAR(100)    NOT NULL
);

CREATE TABLE Interrupcion (
    idInterrupcion          SERIAL          PRIMARY KEY,
    codInterrupcion         VARCHAR(10)     NOT NULL UNIQUE,
	descripcionInterrupcion TEXT			NOT NULL,
    fechaInterrupcion       DATE            NOT NULL,
    duracionInterrupcion    INT             NOT NULL
											CHECK (duracionInterrupcion > 0),
    idTipoInterrupcion      INT             NOT NULL REFERENCES TipoInterrupcion(idTipoInterrupcion),
    idEtapa                 INT             NOT NULL REFERENCES Etapa(idEtapa)
                                            ON DELETE CASCADE,
    idDesarrollador         INT             NOT NULL REFERENCES Usuario(idUsuario)
);

CREATE TABLE MensajeContacto (
    idMensaje           SERIAL          PRIMARY KEY,
    codMensaje          VARCHAR(10)     NOT NULL UNIQUE,
    nombreRemitente     VARCHAR(150)    NOT NULL,
    correoRemitente     VARCHAR(150)    NOT NULL,
    mensaje             TEXT            NOT NULL,
    fechaEnvio          TIMESTAMP       NOT NULL DEFAULT CURRENT_TIMESTAMP,
    estadoMensaje       VARCHAR(20)     NOT NULL DEFAULT 'Pendiente'
                                        CHECK (estadoMensaje IN
                                        ('Pendiente','Leido','Atendido')),
    respuesta           TEXT,
    fechaRespuesta      TIMESTAMP,
    idResponsable       INT             REFERENCES Usuario(idUsuario)
);
