SELECT
    u.codUsuario,
    u.nombre,
    u.apellido,
    r.nombreRol      AS rol,
    p.nombreProfesion AS profesion,
    e.nombreEspecialidad AS especialidad
FROM Usuario u
JOIN Rol         r ON u.idRol        = r.idRol
JOIN Profesion   p ON u.idProfesion  = p.idProfesion
LEFT JOIN Especialidad e ON u.idEspecialidad = e.idEspecialidad
ORDER BY r.nombreRol, u.apellido;

SELECT
    pr.codProyecto,
    pr.nombreProyecto           AS proyecto,
    pr.fechaInicioProyecto,
    pr.fechaFinProyecto,
	pr.estadoProyecto,
    u.nombre || ' ' || u.apellido AS lider,
    CASE WHEN pr.estadoProyecto THEN 'Activo' ELSE 'Inactivo' END AS estado
FROM Proyecto pr
JOIN Usuario u ON pr.idLider = u.idUsuario
ORDER BY pr.fechaInicioProyecto;

SELECT
    pr.nombreProyecto   AS proyecto,
    u.codUsuario,
    u.nombre || ' ' || u.apellido   AS desarrollador,
    ap.fechaAsignacion,
    CASE WHEN ap.estadoAsignacion THEN 'Activo' ELSE 'Inactivo' END AS estadoAsignacion
FROM AsignacionProyecto ap
JOIN Proyecto pr ON ap.idProyecto = pr.idProyecto
JOIN Usuario  u  ON ap.idUsuario  = u.idUsuario
ORDER BY pr.nombreProyecto, u.apellido;

SELECT
    pr.nombreProyecto       AS proyecto,
    et.nombreEtapa       AS etapa,
    a.codActividad,
    a.nombreActividad        AS actividad,
    a.estadoActividad,
    a.fechaEjecucionActividad,
    u.nombre || ' ' || u.apellido AS desarrollador
FROM Actividad a
JOIN Etapa   et ON a.idEtapa        = et.idEtapa
JOIN Proyecto pr ON et.idProyecto   = pr.idProyecto
JOIN Usuario  u  ON a.idDesarrollador = u.idUsuario
ORDER BY pr.nombreProyecto, et.nombreEtapa, a.fechaInicioActividad;

SELECT
    pr.nombreProyecto    AS proyecto,
    et.nombreEtapa       AS etapa,
    i.codInterrupcion,
    i.fechaInterrupcion,
    i.duracionInterrupcion      AS duracion_minutos,
    ti.nombreTipoInterrupcion   AS tipo_interrupcion,
    u.nombre || ' ' || u.apellido AS desarrollador
FROM Interrupcion i
JOIN TipoInterrupcion ti ON i.idTipoInterrupcion = ti.idTipoInterrupcion
JOIN Etapa   et ON i.idEtapa        = et.idEtapa
JOIN Proyecto pr ON et.idProyecto   = pr.idProyecto
JOIN Usuario  u  ON i.idDesarrollador = u.idUsuario
ORDER BY pr.nombreProyecto, i.fechaInterrupcion;

SELECT
    pr.nombreProyecto       AS proyecto,
    et.nombreEtapa       AS etapa,
    e.codError,
    e.fechaRegistroError,
    te.nombreTipo   AS tipo_error,
    e.descripcionError,
	e.estadoError,
    u.nombre || ' ' || u.apellido AS desarrollador
FROM Error e
JOIN TipoError   te ON e.idTipoError    = te.idTipoError
JOIN Etapa       et ON e.idEtapa        = et.idEtapa
JOIN Proyecto    pr ON et.idProyecto    = pr.idProyecto
JOIN Usuario     u  ON e.idDesarrollador = u.idUsuario
ORDER BY pr.nombreProyecto, e.fechaRegistroError;


SELECT
    u.nombre || ' ' || u.apellido   AS desarrollador,
    pr.nombreProyecto                       AS proyecto,
    COUNT(DISTINCT a.idActividad)   AS total_actividades,
    COUNT(DISTINCT CASE WHEN a.estadoActividad = 'Ejecutada'
          THEN a.idActividad END)   AS actividades_ejecutadas,
    COUNT(DISTINCT e.idError)       AS total_errores,
    COUNT(DISTINCT i.idInterrupcion) AS total_interrupciones
FROM Usuario u
LEFT JOIN Actividad    a  ON a.idDesarrollador  = u.idUsuario
LEFT JOIN Etapa        et ON a.idEtapa          = et.idEtapa
LEFT JOIN Proyecto     pr ON et.idProyecto      = pr.idProyecto
LEFT JOIN Error        e  ON e.idDesarrollador  = u.idUsuario
LEFT JOIN Interrupcion i  ON i.idDesarrollador  = u.idUsuario
WHERE u.idUsuario = 3
GROUP BY u.nombre, u.apellido, pr.nombreProyecto;

SELECT
    codMensaje,
    nombreRemitente,
    correoRemitente,
    mensaje,
    fechaEnvio
FROM MensajeContacto
ORDER BY fechaEnvio DESC;

